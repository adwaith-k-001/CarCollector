generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  password_hash    String
  balance          Float     @default(10000)
  garage_capacity  Int       @default(3)
  last_income_time DateTime  @default(now())
  last_login       DateTime?
  last_logout      DateTime?
  last_active      DateTime?
  last_sell_time   DateTime?
  created_at       DateTime  @default(now())

  cars             UserCar[]
  bids             Bid[]
  won_auctions     Auction[]        @relation("HighestBidder")
  skip_votes       AuctionSkipVote[]
  car_history      CarHistoryEntry[]
  trade_offers_sent     TradeOffer[] @relation("TradeOffersFrom")
  trade_offers_received TradeOffer[] @relation("TradeOffersTo")
}

model Car {
  id           String    @id
  name         String    @unique
  category     String
  base_price   Float
  speed        Int
  style        Int
  reliability  Int
  income_rate  Float
  image_path   String

  user_cars           UserCar[]
  auctions            Auction[]
  available_instances AvailableCarInstance[]
  junkyard_cars       JunkyardCar[]
  history_entries     CarHistoryEntry[]
  trade_offers        TradeOffer[]
}

model Auction {
  id                  Int      @id @default(autoincrement())
  car_id              String
  instance_key        String?  // null = brand-new car; set = used car from pool
  start_condition     Float    @default(1.0)
  current_highest_bid Float
  highest_bidder_id   Int?
  start_time          DateTime @default(now())
  end_time            DateTime
  is_active           Boolean  @default(true)

  tune_stage          Int      @default(0)
  variant             String   @default("clean")
  last_seller_id      Int?     // if set, this user cannot win this auction

  car            Car      @relation(fields: [car_id], references: [id])
  highest_bidder User?    @relation("HighestBidder", fields: [highest_bidder_id], references: [id])
  bids           Bid[]
  skip_votes     AuctionSkipVote[]
}

model UserCar {
  id             Int      @id @default(autoincrement())
  instance_key   String   @unique @default(dbgenerated("gen_random_uuid()::text"))
  user_id        Int
  car_id         String
  acquired_at    DateTime @default(now())
  purchase_time  DateTime @default(now())
  purchase_price Float    @default(0)
  condition      Float    @default(1.0)
  tune_stage     Int      @default(0)   // 0=stock 1=Stage1 2=Stage2 3=Stage3
  variant        String   @default("clean") // "performance" | "clean" | "stock"

  user User @relation(fields: [user_id], references: [id])
  car  Car  @relation(fields: [car_id], references: [id])
}

// Cars sold by players, waiting to be re-auctioned
model AvailableCarInstance {
  id             Int      @id @default(autoincrement())
  instance_key   String   @unique
  car_id         String
  condition      Float
  tune_stage     Int      @default(0)
  variant        String   @default("clean")
  last_seller_id Int?     // prevents the seller from immediately buying it back
  listed_at      DateTime @default(now())

  car Car @relation(fields: [car_id], references: [id])
}

// Cars that reached 20% condition and were decommissioned
model JunkyardCar {
  id             Int      @id @default(autoincrement())
  instance_key   String   @unique
  car_id         String
  condition      Float
  junked_at      DateTime @default(now())
  last_owner_id  Int?
  last_username  String?

  car Car @relation(fields: [car_id], references: [id])
}

// Full ownership + event log per car instance
model CarHistoryEntry {
  id           Int      @id @default(autoincrement())
  instance_key String
  car_id       String
  user_id      Int?
  username     String
  event        String   // "won_auction" | "sold" | "junked"
  condition    Float
  price        Float?
  created_at   DateTime @default(now())

  car  Car   @relation(fields: [car_id], references: [id])
  user User? @relation(fields: [user_id], references: [id])
}

model Bid {
  id         Int      @id @default(autoincrement())
  auction_id Int
  user_id    Int
  amount     Float
  created_at DateTime @default(now())

  auction Auction @relation(fields: [auction_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])
}

// P2P trade offers between players
model TradeOffer {
  id           Int      @id @default(autoincrement())
  from_user_id Int
  to_user_id   Int
  instance_key String   // plain string — no FK, survives ownership transfer
  car_id       String
  offer_price  Float
  status       String   @default("pending") // "pending" | "accepted" | "rejected" | "expired"
  is_counter   Boolean  @default(false)     // false = to_user acts; true = from_user acts
  created_at   DateTime @default(now())
  expires_at   DateTime

  from_user  User @relation("TradeOffersFrom", fields: [from_user_id], references: [id])
  to_user    User @relation("TradeOffersTo",   fields: [to_user_id],   references: [id])
  car        Car  @relation(fields: [car_id], references: [id])
}

model AuctionSkipVote {
  auction_id Int
  user_id    Int
  created_at DateTime @default(now())

  auction Auction @relation(fields: [auction_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@id([auction_id, user_id])
}
